# ===========================================
# shadcn UI
# ===========================================
alias shadcn='pnpm dlx shadcn@latest'
alias shadcn-add='pnpm dlx shadcn@latest add'
alias shadcn-mcp='pnpm dlx shadcn@latest mcp init'

shadcn-lyra() {
  pnpm dlx shadcn@latest create \
    --preset "https://ui.shadcn.com/init?base=radix&style=lyra&baseColor=gray&theme=blue&iconLibrary=phosphor&font=jetbrains-mono&menuAccent=subtle&menuColor=default&radius=none&template=vite" \
