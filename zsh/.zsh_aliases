# ===========================================
# Helper Functions
# ===========================================

# Create and cd into directory
mkcd() {
  mkdir -p "$1" && cd "$1"
}

# Quick project init with git
proj-init() {
  git init
  touch CLAUDE.md README.md
  echo "# $(basename $(pwd))" > README.md
  git add .
  git commit -m "Initial scaffolding"
}

