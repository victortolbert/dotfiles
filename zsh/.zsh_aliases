}

# ===========================================
# Networking & System
# ===========================================
alias ping='ping -c 5'
alias ip='ifconfig -a | grep -o "inet6\? \(addr:\)\?\s\?\(\(\([0-9]\+\.\)\{3\}[0-9]\+\)\|[a-fA-F0-9:]\+\)" | awk "{ sub(/inet6? (addr:)? ?/, \"\"); print }"'
alias ip_intern='ipconfig getifaddr en0'
alias ip_extern='curl ipecho.net/plain; echo'
alias reloaddns='dscacheutil -flushcache && sudo killall -HUP mDNSResponder'
alias ports='lsof -i -P -n | grep LISTEN'
alias whois='whois -h whois-servers.net'
alias weather='curl -4 http://wttr.in'
alias HEAD='curl -I'

killport() {
  kill $(lsof -t -i :$1) 2>/dev/null || echo "Port $1 not in use"
}

# ===========================================
# Process Management
# ===========================================
alias psjava='ps aux | grep java'
alias psg='ps aux | grep'
alias pg='pgrep -lf'
alias wtf3000="lsof -i tcp:3000"

# ===========================================
# macOS Utilities
# ===========================================
# Toggle dark mode
tdm() {
  osascript -e 'tell app "System Events" to tell appearance preferences to set dark mode to not dark mode'
}

# Hide/show desktop icons (for presentations)
alias hidedesktop='defaults write com.apple.finder CreateDesktop -bool false && killall Finder'
alias showdesktop='defaults write com.apple.finder CreateDesktop -bool true && killall Finder'

# Update everything
alias update='brew update; brew upgrade; brew cleanup; npm update npm -g; npm update -g; sudo gem update --system; sudo gem update'

muppd() {
  echo -e "\033[100;44m"
  sudo softwareupdate -ia
  brew update
  echo -e "\033[0m"
}

