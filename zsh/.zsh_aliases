# ===========================================
# Consolidated Aliases & Functions
# ===========================================
# Source this from .zshrc: source ~/.zsh_aliases
# Edit with: ea (alias below)

# ===========================================
# Shell Settings
# ===========================================
export SHELL='/bin/zsh'
setopt hist_ignore_all_dups inc_append_history
HISTSIZE=4096
SAVEHIST=4096

# Editor configuration
if command -v code-insiders >/dev/null 2>&1; then
  export EDITOR="code-insiders"
elif command -v code >/dev/null 2>&1; then
  export EDITOR="code"
fi
export ESLINT_EDITOR="code-insiders"
export REACT_EDITOR="code-insiders"

# ===========================================
# Navigation
# ===========================================
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'

alias proj='cd ~/Projects'
alias herd='cd ~/Herd'
alias aem='cd ~/aem/author'
alias kb='cd ~/Projects/kb'
alias exemplar='cd ~/Projects/exemplar.core'
alias livewire='cd ~/Herd/livewire-catalog'
alias uxlab='cd ~/Projects/uxlab'

# cd into frontmost Finder window
cdf() {
  cd "$(osascript -e 'tell app "Finder" to POSIX path of (insertion location as alias)')"
}

# ===========================================
# File Operations (with safety prompts)
# ===========================================
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -i'
alias mkdir='mkdir -pv'

# Listing
alias ll='ls -ltr'
alias la='ls -A'
alias lll='ls -la'

# Finder
alias f='open -a Finder'
alias o='open .'

# Tree views
alias tree3='tree -L 3'

t() {
  tree -I '.git|node_modules|bower_components|.DS_Store' --dirsfirst --filelimit 26 -L ${1:-3} -aC $2
}

dir() {
  tree -I '.git|node_modules|bower_components|.DS_Store' --dirsfirst --filelimit 90 -L ${1:-3} -aC $2
}

# ===========================================
# Editors
# ===========================================
alias c='code-insiders'
alias ci='code-insiders'
alias c.='code-insiders .'
alias ws='windsurf .'
alias slime='subl'

# Quick config editing
alias ea='code-insiders ~/.zsh_aliases'
alias ez='code-insiders ~/.zshrc'

# ===========================================
# Git
# ===========================================
alias g='git'
alias gs='git status -sb'
alias ga='git add .'
alias gc='git commit -m'
alias gp='git push'
alias gpu='git push -u origin'
alias gpl='git pull'
alias gf='git fetch'
alias gco='git checkout'
alias gb='git branch'
alias grv='git remote -v'
alias glog='git log --oneline -10'
alias glog3='git log --oneline -3'

# Undo everything (careful!)
alias nah='git reset --hard && git clean -df'

# Quick commits
alias wip="git add . && git commit -m 'wip'"
alias init="git init && git add . && git commit -m '✨ Initial commit'"

# Multi-repo helpers (for titan-common style projects)
gitpull() {
  if [ -d titan-common ]; then
    cd titan-common
    echo -e "\e[0;32m${PWD##*/}\e[0m"
    git pull origin $1
    cd ..
  fi
  echo -e "\e[0;32m${PWD##*/}\e[0m"
  git pull origin $1
}

gitpush() {
  if [ -d titan-common ]; then
    cd titan-common
    echo -e "\e[0;32m${PWD##*/}\e[0m"
    git push -u origin HEAD
    cd ..
  fi
  echo -e "\e[0;32m${PWD##*/}\e[0m"
  git push -u origin HEAD
}

gitadd() {
  echo -e "\e[0;32m${PWD##*/}\e[0m"
  git add . --all
  if [ -d titan-common ]; then
    cd titan-common
    echo -e "\e[0;32m${PWD##*/}\e[0m"
    git add . --all
    cd ..
  fi
}

gitstash() {
  if [ -d titan-common ]; then
    echo -e "\e[0;32m${PWD##*/}\e[0m"
    cd titan-common
    git stash $1
    cd ..
  fi
  echo -e "\e[0;32m${PWD##*/}\e[0m"
  git stash $1
}

gitstatus() {
  if [ -d titan-common ]; then
    cd titan-common
    echo -e "\e[0;32m${PWD##*/}\e[0m"
    git status
    cd ..
  fi
  echo -e "\e[0;32m${PWD##*/}\e[0m"
  git status
}

gitmerge() {
  if [ -d titan-common ]; then
    cd titan-common
    echo -e "\e[0;32m${PWD##*/}\e[0m"
    git merge $1
    cd ..
  fi
  echo -e "\e[0;32m${PWD##*/}\e[0m"
  git merge $1
}

# Git changelog generator
git-changelog() {
  local base=${1:-$(git merge-base origin/main HEAD)}
  echo "## Changelog"
  echo
  echo "### ✨ Features"
  git log --no-merges --pretty=format:"- %s" "$base"..HEAD | grep -i "feat" || echo "None"
  echo
  echo "### 🐛 Fixes"
  git log --no-merges --pretty=format:"- %s" "$base"..HEAD | grep -i "fix" || echo "None"
  echo
  echo "### 📚 Documentation"
  git log --no-merges --pretty=format:"- %s" "$base"..HEAD | grep -i "docs" || echo "None"
}

# ===========================================
# Package Managers
# ===========================================
# pnpm
alias p='pnpm'
alias i='pnpm install'
alias d='pnpm dev'
alias pd='pnpm dev'
alias b='pnpm build'
alias pb='pnpm build'
alias pt='pnpm test'
alias l='pnpm lint'
alias pl='pnpm lint'
alias lf='pnpm lint:fix'
alias plf='pnpm lint:fix'
alias tc='pnpm typecheck'
alias ptc='pnpm typecheck'
alias pab='pnpm approve-builds'
alias itc='pnpm i && pnpm typecheck'

# bun
alias bi='bun install'
alias bd='bun dev'
alias br='bun run'
alias bl='bun lint'
alias blf='bun lint:fix'
alias btc='bun typecheck'
alias bt='bun run test'

# npm
alias ni='npm install'
alias nid='npm install -D'

# Nuxt clean rebuilds (very common workflow)
alias fresh='rm -rf .nuxt .data node_modules pnpm-lock.yaml && pnpm install'
alias nuxt-reset='rm -rf .nuxt .data .output pnpm-lock.yaml && bun install'
alias nuxt-dev='rm -rf .nuxt .data .output pnpm-lock.yaml && bun install && bun dev'
alias nuxt-lint='rm -rf .nuxt .data .output pnpm-lock.yaml && bun install && bun lint'
alias nuxt-test='rm -rf .nuxt .data .output pnpm-lock.yaml && bun install && bun run test'
alias nuxt-check='rm -rf .nuxt .data .output pnpm-lock.yaml && bun install && bun typecheck'

# ===========================================
# Java / AEM
# ===========================================
alias java11='export JAVA_HOME=$(/usr/libexec/java_home -v 11)'
alias java17='export JAVA_HOME=$(/usr/libexec/java_home -v 17)'
alias jv='java -version'

# AEM UI Build (PHP dev server — root at ~/Projects/ivy so /admp-ivy/... paths resolve via symlink)
ivyui() {
  local url="http://localhost:8080/admp-ivy/common-elements-aem-parent/ui.apps/src/main/content/jcr_root/apps/common-elements/admp-ui.php"
  echo "Ivy UI: $url"
  open "$url"
  php -S localhost:8080 -t ~/Projects
}

# AEM instance management
alias aem-start='cd ~/aem/author && java \
  -server -Xms2g -Xmx6g -XX:+UseG1GC \
  -Djava.awt.headless=true \
  -Djava.locale.providers=CLDR,JRE,SPI \
  -Dsling.run.modes=author,crx3,crx3tar \
  -Dsling.properties=conf/sling.properties \
  -Doak.segment.msync=true \
  --add-opens=java.desktop/com.sun.imageio.plugins.jpeg=ALL-UNNAMED \
  --add-opens=java.base/sun.net.www.protocol.jrt=ALL-UNNAMED \
  --add-opens=java.naming/javax.naming.spi=ALL-UNNAMED \
  --add-opens=java.xml/com.sun.org.apache.xerces.internal.dom=ALL-UNNAMED \
  --add-opens=java.base/java.lang=ALL-UNNAMED \
  --add-opens=java.base/jdk.internal.reflect=ALL-UNNAMED \
  -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=5005 \
  -jar aem65-author-p4502.jar -p 4502 -nointeractive'
alias aem-stop='curl -u admin:admin -X POST "http://localhost:4502/system/console/configMgr/org.apache.sling.launcher.system.SlingMainServlet" -d "apply=true" -d "action=stop"'
alias aem-status='ps -ef | grep aem65-author-p4502.jar | grep -v grep'
alias aem-log='tail -f ~/aem/author/crx-quickstart/logs/error.log'
alias aem-errors='grep -i "error\|exception" ~/aem/author/crx-quickstart/logs/error.log | tail -50'

# AEM project archetype (interactive)
alias aem-new='mvn archetype:generate \
  -DarchetypeGroupId=com.adobe.aem \
  -DarchetypeArtifactId=aem-project-archetype \
  -DarchetypeVersion=37 \
  -DaemVersion=6.5.0'

# Full AEM project creation
aem-create() {
  local name=${1:-myproject}
  local group=${2:-com.mycompany}
  local title=${3:-"My Project"}

  mvn archetype:generate \
    -DarchetypeGroupId=com.adobe.aem \
    -DarchetypeArtifactId=aem-project-archetype \
    -DarchetypeVersion=37 \
    -DaemVersion=6.5.0 \
    -DgroupId="$group" \
    -DartifactId="$name" \
    -Dversion=1.0.0-SNAPSHOT \
    -Dpackage="$group.$name" \
    -DappsFolderName="$name" \
    -DcontentFolderName="$name" \
    -DcssId="$name" \
    -DcomponentGroupName="$title" \
    -DartifactName="$title" \
    -DappTitle="$title"
}

# AEM React SPA project
aem-create-spa() {
  local name=${1:-myaemreact}
  local group=${2:-com.mycompany}
  local title=${3:-"My AEM React Project"}

  mvn archetype:generate \
    -DarchetypeGroupId=com.adobe.aem \
    -DarchetypeArtifactId=aem-project-archetype \
    -DarchetypeVersion=37 \
    -DaemVersion=6.5.14 \
    -DgroupId="$group" \
    -DartifactId="$name" \
    -Dversion=1.0.0-SNAPSHOT \
    -DappTitle="$title" \
    -DappId="$name" \
    -DoptionSPA=y \
    -DfrontendModule=react \
    -DincludeExamples=n
}

